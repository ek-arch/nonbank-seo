# .streamlit/secrets.toml — example / schema reference
#
# Copy this file to .streamlit/secrets.toml and fill in real values.
# The real file is gitignored.
#
# For Streamlit Cloud deployment, paste these same values into:
#   Manage app → Settings → Secrets

# ─── Anthropic Claude (REQUIRED for generation features) ─────────────
# Get from: https://console.anthropic.com → API Keys
# Used by: PR Generator, Distribution, Content Plan (brief generator),
#          Monthly Planner, GEO Tracker (prompt discovery),
#          Content Brief Factory, Competitor Intel
ANTHROPIC_API_KEY = "sk-ant-api03-REPLACE_WITH_REAL_KEY"

# ─── Perplexity (recommended for AI visibility / GEO features) ───────
# Get from: https://www.perplexity.ai/settings/api
# Used by: Competitor Intel (AI Visibility Audit),
#          Keyword Intel (AI check),
#          GEO Tracker (prompt monitoring)
PERPLEXITY_KEY = "pplx-REPLACE_WITH_REAL_KEY"

# ─── SerpAPI (recommended for SERP / competitor research) ────────────
# Get from: https://serpapi.com → Dashboard → Your Private API Key
# Free tier: 100 searches/month
# Used by: Competitor Intel (Keyword Spy),
#          Keyword Intel (autocomplete expansion, SERP checks),
#          Distribution (Reddit/Quora/X thread discovery)
SERPAPI_KEY = "REPLACE_WITH_REAL_KEY"


# ─── Google Sheets service account (optional, for Content Plan sync) ──
# Setup:
#   1. https://console.cloud.google.com → create/select project
#   2. Enable Google Sheets API + Google Drive API
#   3. IAM & Admin → Service Accounts → Create
#   4. Keys → Add Key → JSON → download
#   5. Paste JSON fields here
#   6. Share your target Google Sheet with the `client_email` below
#      (give it Editor access)
#
# Used by: Content Plan (load/save publication calendar),
#          Distribution (push comments tracker)

[gsheets]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "REPLACE_WITH_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_FULL_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
client_email = "service-account-name@your-project.iam.gserviceaccount.com"
client_id = "REPLACE_WITH_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/service-account-name%40your-project.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
